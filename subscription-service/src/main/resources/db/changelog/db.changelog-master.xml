                 stripComments="true"/>
        <comment>Subscription initializer</comment>
    </changeSet>

    <changeSet id="trkcl_02" author="Egehan Yalçın">
        <sqlFile path="02_outbox.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
        <comment>Outbox initializer</comment>
    </changeSet>

    <changeSet id="trkcl_03" author="Egehan Yalçın">
        <sqlFile path="03_shedlock.sql"
                 relativeToChangelogFile="true"
                 splitStatements="true"
                 stripComments="true"/>
        <comment>Shedlock initializer</comment>
    </changeSet>

</databaseChangeLog>